import {
    StandardTableView,
    ComboBox,
    LineEdit,
    Button,
    AboutSlint,
} from "std-widgets.slint";

export global Sender {
    in-out property <int> led_pattern: 0;
    callback test-send-data();
}

export global Helper {
    in-out property <[string]> display-patterns;
}

export global DisplayRadarData {
    in property <[TableColumn]> test-packet-columns;
    in property <[[StandardListViewItem]]> test-packets;
}

export global ImageStream {
    in property <image> image;
}

export global CameraSettings {
    in-out property <[string]> frame-sizes;

    in-out property <int> stream-type-index: 0;
    in-out property <int> jpeg-quality: 12;
    in-out property <float> brightness: 0;
    in-out property <float> contrast: 0;
    in-out property <float> saturation: 0;
    in-out property <float> sharpness: 0;
}

component SettingBox inherits VerticalLayout {
    in property <string> label;

    alignment: start;

    i-label := Text {
        text: root.label;
    }

    Rectangle {
        @children
    }
}

export component MainWindow inherits Window {

    about_dialog := PopupWindow {
        AboutSlint { }
    }

    MenuBar {
        Menu {
            title: @tr("Attributions");
            MenuItem {
                title: @tr("View Attributions");
                activated => {
                    about_dialog.show();
                }
            }
        }
    }

    VerticalLayout {
        HorizontalLayout {
            spacing: 10px;

            VerticalLayout {
                alignment: start;

                padding: 10px;
                spacing: 12px;

                SettingBox {
                    label: "Frame Size";

                    ComboBox {
                        model: CameraSettings.frame-sizes;
                    }
                }

                SettingBox {
                    label: "JPEG Quality";
                    LineEdit { }
                }

                SettingBox {
                    label: "Brightness";
                    LineEdit { }
                }

                SettingBox {
                    label: "Contrast";
                    LineEdit { }
                }

                SettingBox {
                    label: "Saturation";
                    LineEdit { }
                }

                SettingBox {
                    label: "Sharpness";
                    LineEdit { }
                }
            }

            VerticalLayout {
                alignment: start;

                Rectangle {
                    ComboBox {
                        model: Helper.display-patterns;
                        current-index: 0;

                        changed current-index => {
                            Sender.led_pattern = self.current-index;
                            Sender.test-send-data();
                        }
                    }
                }
            }

            StandardTableView {
                columns: DisplayRadarData.test-packet-columns;
                rows: DisplayRadarData.test-packets;
            }

            i-stream-image := Image {
                width: 50%;
                source: ImageStream.image;
            }
        }
    }
}
